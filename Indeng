<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>UK Visa Application Form</title>
  <!-- Google Fonts — works fine on GitHub Pages (external CSS, no CORS issue) -->
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --navy: #0D1B2A;
      --royal: #1A3A5C;
      --blue: #1E5FA3;
      --accent: #C8A96E;
      --accent-light: #F0E6D3;
      --surface: #FFFFFF;
      --surface-2: #F6F8FB;
      --border: #D8E2EE;
      --text: #1A2535;
      --text-muted: #607080;
      --input-bg: #FAFCFF;
      --danger: #C0392B;
      --success: #1A7A4A;
      --radius: 8px;
      --section-gap: 48px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: #EDF1F7;
      color: var(--text);
      min-height: 100vh;
      padding: 32px 16px 64px;
    }

    /* ───── HEADER ───── */
    .form-header {
      max-width: 820px;
      margin: 0 auto 28px;
      display: flex;
      align-items: center;
      gap: 18px;
    }
    .crest {
      width: 52px; height: 52px;
      background: var(--navy);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .crest svg { width: 32px; height: 32px; }
    .header-text h1 {
      font-family: 'Playfair Display', serif;
      font-size: 22px;
      color: var(--navy);
      letter-spacing: 0.01em;
    }
    .header-text p {
      font-size: 12px;
      color: var(--text-muted);
      font-weight: 400;
      margin-top: 2px;
    }

    /* ───── PROGRESS BAR ───── */
    .progress-bar-wrap {
      max-width: 820px;
      margin: 0 auto 24px;
    }
    .progress-labels {
      display: flex;
      justify-content: space-between;
      font-size: 10px;
      color: var(--text-muted);
      margin-bottom: 6px;
      font-weight: 500;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .progress-track {
      height: 4px;
      background: var(--border);
      border-radius: 999px;
      overflow: hidden;
    }
    .progress-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--blue), var(--accent));
      border-radius: 999px;
      width: 0%;
      transition: width 0.5s ease;
    }

    /* ───── CARD / SECTION ───── */
    .form-card {
      max-width: 820px;
      margin: 0 auto 20px;
      background: var(--surface);
      border-radius: 14px;
      border: 1px solid var(--border);
      overflow: hidden;
      box-shadow: 0 2px 16px rgba(13,27,42,0.06);
    }
    .section-header {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 20px 28px;
      background: linear-gradient(135deg, var(--navy) 0%, var(--royal) 100%);
      cursor: pointer;
      user-select: none;
    }
    .section-icon {
      width: 36px; height: 36px;
      background: rgba(255,255,255,0.1);
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      color: var(--accent);
      font-size: 16px;
      flex-shrink: 0;
    }
    .section-header h2 {
      font-family: 'Playfair Display', serif;
      font-size: 16px;
      color: #fff;
      font-weight: 600;
      flex: 1;
    }
    .section-number {
      font-size: 11px;
      color: rgba(255,255,255,0.5);
      font-weight: 500;
    }
    .chevron {
      color: rgba(255,255,255,0.6);
      transition: transform 0.3s;
      font-size: 14px;
    }
    .section-header.collapsed .chevron { transform: rotate(-90deg); }
    .section-body {
      padding: 24px 28px;
    }
    .section-body.hidden { display: none; }

    /* ───── FIELD GRID ───── */
    .field-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px 24px;
    }
    .field-grid .full { grid-column: 1 / -1; }

    /* ───── FORM FIELD ───── */
    .field {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .field label {
      font-size: 12px;
      font-weight: 600;
      color: var(--text-muted);
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .field input[type="text"],
    .field input[type="email"],
    .field input[type="tel"],
    .field input[type="number"],
    .field input[type="date"],
    .field select,
    .field textarea {
      width: 100%;
      padding: 10px 14px;
      border: 1.5px solid var(--border);
      border-radius: var(--radius);
      font-family: 'DM Sans', sans-serif;
      font-size: 14px;
      color: var(--text);
      background: var(--input-bg);
      transition: border-color 0.2s, box-shadow 0.2s;
      outline: none;
    }
    .field input:focus,
    .field select:focus,
    .field textarea:focus {
      border-color: var(--blue);
      box-shadow: 0 0 0 3px rgba(30,95,163,0.1);
    }
    .field textarea {
      min-height: 110px;
      resize: vertical;
      line-height: 1.6;
    }

    /* ───── RADIO / CHECKBOX ───── */
    .radio-group, .checkbox-row {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      align-items: center;
      margin-top: 2px;
    }
    .radio-pill {
      display: flex;
      align-items: center;
      gap: 7px;
      padding: 8px 16px;
      border: 1.5px solid var(--border);
      border-radius: 999px;
      cursor: pointer;
      font-size: 13px;
      font-weight: 500;
      color: var(--text);
      transition: all 0.2s;
      background: var(--input-bg);
      user-select: none;
    }
    .radio-pill input[type="radio"],
    .radio-pill input[type="checkbox"] {
      appearance: none;
      width: 15px; height: 15px;
      border: 2px solid var(--border);
      border-radius: 50%;
      flex-shrink: 0;
      transition: all 0.2s;
      cursor: pointer;
    }
    .radio-pill input[type="checkbox"] { border-radius: 4px; }
    .radio-pill:has(input:checked) {
      border-color: var(--blue);
      background: rgba(30,95,163,0.06);
      color: var(--blue);
    }
    .radio-pill input[type="radio"]:checked,
    .radio-pill input[type="checkbox"]:checked {
      background: var(--blue);
      border-color: var(--blue);
      box-shadow: inset 0 0 0 3px #fff;
    }

    /* ───── CONDITIONAL FIELDS ───── */
    .conditional-field {
      display: none;
      padding: 16px;
      background: var(--accent-light);
      border-left: 3px solid var(--accent);
      border-radius: 0 var(--radius) var(--radius) 0;
      margin-top: 6px;
    }
    .conditional-field .field-grid { gap: 14px 20px; }

    /* ───── SUBSECTION ───── */
    .subsection {
      margin-top: 20px;
      padding-top: 20px;
      border-top: 1px dashed var(--border);
    }
    .subsection-title {
      font-size: 13px;
      font-weight: 600;
      color: var(--royal);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 14px;
    }

    /* ───── DYNAMIC ENTRIES ───── */
    .dynamic-entry {
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 16px;
      margin-bottom: 12px;
    }
    .dynamic-entry-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 14px;
    }
    .dynamic-entry-title {
      font-size: 13px;
      font-weight: 600;
      color: var(--royal);
    }
    .btn-remove {
      background: none;
      border: 1px solid #e2c5c5;
      color: var(--danger);
      padding: 4px 10px;
      border-radius: 6px;
      font-size: 12px;
      cursor: pointer;
      font-family: 'DM Sans', sans-serif;
    }
    .btn-remove:hover { background: #fff0f0; }

    /* ───── BUTTONS ───── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 20px;
      border-radius: var(--radius);
      font-family: 'DM Sans', sans-serif;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      border: none;
      transition: all 0.2s;
    }
    .btn-add {
      background: rgba(30,95,163,0.08);
      color: var(--blue);
      border: 1.5px dashed rgba(30,95,163,0.3);
      width: 100%;
      justify-content: center;
      margin-top: 8px;
    }
    .btn-add:hover { background: rgba(30,95,163,0.14); }
    .btn-primary {
      background: linear-gradient(135deg, var(--navy), var(--blue));
      color: #fff;
      padding: 14px 36px;
      font-size: 15px;
      box-shadow: 0 4px 18px rgba(13,27,42,0.22);
    }
    .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 6px 22px rgba(13,27,42,0.28); }
    .btn-danger-sm {
      background: #fff0f0;
      color: var(--danger);
      border: 1px solid #f0cccc;
      font-size: 12px;
      padding: 6px 14px;
    }

    /* ───── SIGNATURE ───── */
    .signature-wrap {
      border: 1.5px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      background: var(--input-bg);
    }
    .signature-label-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 8px 14px;
      background: var(--surface-2);
      border-bottom: 1px solid var(--border);
      font-size: 12px;
      color: var(--text-muted);
    }
    #signatureBox {
      display: block;
      width: 100%;
      height: 130px;
      cursor: crosshair;
    }

    /* ───── DOCUMENTS LIST ───── */
    .doc-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .doc-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 11px 14px;
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      cursor: pointer;
      transition: all 0.18s;
      font-size: 13.5px;
      font-weight: 500;
    }
    .doc-item::before {
      content: '⊞';
      color: var(--accent);
      font-size: 16px;
      flex-shrink: 0;
    }
    .doc-item:hover, .doc-item.active-doc {
      border-color: var(--blue);
      background: rgba(30,95,163,0.05);
      color: var(--blue);
    }
    .doc-item.active-doc::before { content: '✔'; color: var(--success); }
    .doc-details-display {
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 18px;
      margin-top: 14px;
    }
    .doc-details-display h3 {
      font-family: 'Playfair Display', serif;
      color: var(--royal);
      font-size: 15px;
      margin-bottom: 8px;
    }
    .doc-details-display .purpose {
      color: var(--text-muted);
      font-size: 13px;
      margin-bottom: 10px;
    }
    .doc-details-display ul {
      padding-left: 18px;
      font-size: 13px;
      line-height: 1.8;
      color: var(--text);
    }

    /* ───── FOOTER / SUBMIT AREA ───── */
    .submit-area {
      max-width: 820px;
      margin: 0 auto;
      text-align: center;
      padding: 12px 0 0;
    }
    .submit-area p {
      font-size: 12px;
      color: var(--text-muted);
      margin-top: 12px;
    }

    /* ───── DIVIDER ───── */
    .divider {
      height: 1px;
      background: var(--border);
      margin: 22px 0;
    }

    /* ───── NOTICE BOX ───── */
    .notice-box {
      background: #FFF8ED;
      border: 1px solid #E8C97C;
      border-radius: var(--radius);
      padding: 14px 16px;
      font-size: 13px;
      line-height: 1.6;
      color: #7A5D20;
      margin-bottom: 16px;
    }
    .notice-box strong { color: #5A3E0A; }

    @media (max-width: 600px) {
      .field-grid { grid-template-columns: 1fr; }
      .section-body { padding: 18px 16px; }
      .form-header { flex-direction: column; align-items: flex-start; }
    }
  </style>
</head>
<body>


<!-- HEADER -->
<div class="form-header">
  <div class="crest">
    <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="16" cy="16" r="14" stroke="#C8A96E" stroke-width="1.5"/>
      <path d="M10 12h12M10 16h12M10 20h12" stroke="#C8A96E" stroke-width="1.5" stroke-linecap="round"/>
      <rect x="14" y="6" width="4" height="4" rx="1" fill="#C8A96E"/>
    </svg>
  </div>
  <div class="header-text">
    <h1>UK Visa Application Form</h1>
    <p>Student / General — Please complete all sections accurately before generating your PDF.</p>
  </div>
</div>

<!-- PROGRESS -->
<div class="progress-bar-wrap">
  <div class="progress-labels">
    <span>Personal</span><span>Family</span><span>Travel</span><span>Statement</span><span>Declaration</span>
  </div>
  <div class="progress-track"><div class="progress-fill" id="progressFill"></div></div>
</div>

<!-- ══════ SECTION 1: PERSONAL INFORMATION ══════ -->
<div class="form-card" id="card-personal">
  <div class="section-header" onclick="toggleSection('personal')">
    <div class="section-icon">👤</div>
    <h2>Personal Information</h2>
    <span class="section-number">01</span>
    <span class="chevron">▼</span>
  </div>
  <div class="section-body" id="body-personal">
    <div class="field-grid">
      <div class="field">
        <label>Given Name(s)</label>
        <input type="text" id="givenNames" name="givenNames" placeholder="e.g. John">
      </div>
      <div class="field">
        <label>Family Name</label>
        <input type="text" id="familyName" name="familyName" placeholder="e.g. Smith">
      </div>
      <div class="field full">
        <label>Have you ever been known by any other name?</label>
        <div class="radio-group">
          <label class="radio-pill"><input type="radio" name="otherName" id="otherNameYes" value="Yes"> Yes</label>
          <label class="radio-pill"><input type="radio" name="otherName" id="otherNameNo" value="No"> No</label>
        </div>
        <div class="conditional-field" id="previousNamesField">
          <div class="field-grid">
            <div class="field full">
              <label>Previous Name(s)</label>
              <input type="text" id="previousNames" name="previousNames">
            </div>
          </div>
        </div>
      </div>
      <div class="field">
        <label>Relationship Status</label>
        <input type="text" id="relationshipStatus" name="relationshipStatus" placeholder="e.g. Single, Married">
      </div>
      <div class="field">
        <label>University / Institution</label>
        <input type="text" id="institution" name="institution" placeholder="Enter institution name">
      </div>
      <div class="field full">
        <label>Do you hold or have ever held any other nationality or citizenship?</label>
        <div class="radio-group">
          <label class="radio-pill"><input type="radio" name="otherNationality" id="otherNationalityYes" value="Yes"> Yes</label>
          <label class="radio-pill"><input type="radio" name="otherNationality" id="otherNationalityNo" value="No"> No</label>
        </div>
        <div class="conditional-field" id="otherNationalityField">
          <div class="field">
            <label>Other Nationality / Citizenship</label>
            <input type="text" id="otherNationalityDetails" name="otherNationalityDetails">
          </div>
        </div>
      </div>
      <div class="field full">
        <label>Current Address</label>
        <input type="text" id="currentAddress" name="currentAddress" placeholder="Full current residential address">
      </div>
      <div class="field full">
        <label>Is this address your correspondence address?</label>
        <div class="radio-group">
          <label class="radio-pill"><input type="radio" name="correspondence" id="correspondenceYes" value="Yes"> Yes</label>
          <label class="radio-pill"><input type="radio" name="correspondence" id="correspondenceNo" value="No"> No</label>
        </div>
        <div class="conditional-field" id="correspondenceAddressField">
          <div class="field">
            <label>Correspondence Address</label>
            <input type="text" id="correspondenceAddress" name="correspondenceAddress">
          </div>
        </div>
      </div>
      <div class="field">
        <label>How long at this address?</label>
        <input type="text" id="addressDuration" name="addressDuration" placeholder="e.g. 2 years">
      </div>
      <div class="field">
        <label>Home Ownership Status</label>
        <div class="radio-group" style="margin-top:4px">
          <label class="radio-pill"><input type="radio" name="ownership" id="owned" value="Owned"> Owned</label>
          <label class="radio-pill"><input type="radio" name="ownership" id="rented" value="Rented"> Rented</label>
          <label class="radio-pill"><input type="radio" name="ownership" id="otherOwnership" value="Other"> Other</label>
        </div>
      </div>
      <div class="field full">
        <label>Do you have a UK driving licence?</label>
        <div class="radio-group">
          <label class="radio-pill"><input type="radio" name="license" id="licenseYes" value="Yes"> Yes</label>
          <label class="radio-pill"><input type="radio" name="license" id="licenseNo" value="No"> No</label>
        </div>
        <div class="conditional-field" id="licenseNumberField">
          <div class="field">
            <label>UK Driving Licence Number</label>
            <input type="text" id="licenseNumber" name="licenseNumber">
          </div>
        </div>
      </div>
      <div class="field">
        <label>Telephone Number</label>
        <input type="tel" id="telephone" name="telephone" placeholder="+234 …">
      </div>
      <div class="field">
        <label>Email Address</label>
        <input type="email" id="email" name="email" placeholder="example@email.com">
      </div>
    </div>
  </div>
</div>

<!-- ══════ SECTION 2: SPOUSE / PARTNER ══════ -->
<div class="form-card" id="card-spouse">
  <div class="section-header collapsed" onclick="toggleSection('spouse')">
    <div class="section-icon">💑</div>
    <h2>Spouse / Partner Details</h2>
    <span class="section-number">02</span>
    <span class="chevron">▼</span>
  </div>
  <div class="section-body hidden" id="body-spouse">
    <div class="field-grid">
      <div class="field">
        <label>Relationship to You</label>
        <input type="text" id="spouseRelationship" name="spouseRelationship" placeholder="e.g. Spouse">
      </div>
      <div class="field">
        <label>Date of Birth</label>
        <input type="date" id="spouseDob" name="spouseDob">
      </div>
      <div class="field">
        <label>Given Name(s)</label>
        <input type="text" id="spouseGivenNames" name="spouseGivenNames">
      </div>
      <div class="field">
        <label>Family Name</label>
        <input type="text" id="spouseFamilyName" name="spouseFamilyName">
      </div>
      <div class="field full">
        <label>Does your spouse/partner currently live with you?</label>
        <div class="radio-group">
          <label class="radio-pill"><input type="radio" name="spouseLive" id="spouseLiveYes" value="Yes"> Yes</label>
          <label class="radio-pill"><input type="radio" name="spouseLive" id="spouseLiveNo" value="No"> No</label>
        </div>
      </div>
      <div class="field full">
        <label>Is your spouse/partner travelling with you to the UK?</label>
        <div class="radio-group">
          <label class="radio-pill"><input type="radio" name="spouseTravel" id="spouseTravelYes" value="Yes"> Yes</label>
          <label class="radio-pill"><input type="radio" name="spouseTravel" id="spouseTravelNo" value="No"> No</label>
        </div>
        <div class="conditional-field" id="spousePassportField">
          <div class="field">
            <label>Spouse / Partner's Passport Number</label>
            <input type="text" id="spousePassport" name="spousePassport">
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ══════ SECTION 3: PARENT DETAILS ══════ -->
<div class="form-card" id
